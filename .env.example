# === DigitalHub Config ===
NODE_ENV=production
PORT=3000
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_rahasia
SITE_NAME=DigitalHub

# Kunci enkripsi buat API key sensitif yang disimpan di database (AES-256-GCM).
# WAJIB diisi sebelum produksi — generate dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Admin (Owner - akses penuh termasuk Developer)
# PENTING: ganti password ini sebelum web live publik!
OWNER_USERNAME=Rasya111
OWNER_PASSWORD=Bmbm12133

# Password buat buka tab "Developer" di admin panel (fitur tingkat lanjut)
DEVELOPER_PASSWORD=86868686

# === Firebase (Admin SDK — WAJIB diisi, beda dari firebaseConfig di browser) ===
# Cara dapetin: Firebase Console -> Project Settings -> Service Accounts ->
# "Generate new private key" -> salin 3 nilai dari file JSON yang didownload.
FIREBASE_PROJECT_ID=digitalhub-c12
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=https://digitalhub-c12-default-rtdb.asia-southeast1.firebasedatabase.app
# Provider PPOB H2H (mis. Digiflazz, dsb) — kosongkan untuk mode simulasi
H2H_BASE_URL=
H2H_API_KEY=
H2H_USERNAME=

# Provider OTP / virtual number (mis. SMSPVA, dsb) — kosongkan untuk mode simulasi
OTP_PROVIDER_BASE_URL=
OTP_PROVIDER_API_KEY=

# Panel hosting (Pterodactyl) — kosongkan untuk mode simulasi
PANEL_PTERO_URL=
PANEL_PTERO_API_KEY=

# TikTok Downloader (opsional, default sudah diisi endpoint publik TikWM)
TIKWM_ENDPOINT=https://www.tikwm.com/api/
